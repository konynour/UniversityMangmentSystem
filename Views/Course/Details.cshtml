@model FinalProject.Models.Course
@{ ViewData["Title"] = "Course Details"; }

<div class="card mx-auto" style="max-width:600px">
    <div class="card-header"><h4 class="mb-0"><i class="bi bi-book me-2"></i>Course Details</h4></div>
    <div class="card-body">
        <p><strong>Name:</strong> @Model.Name</p>
        <p><strong>Degree:</strong> @Model.Degree</p>
        <p><strong>Min Degree:</strong> @Model.MinDegree</p>
        <p><strong>Hours:</strong> @Model.Hours</p>
        <p><strong>Department:</strong> @Model.Department?.Name</p>
    </div>
    <div class="card-footer">
        <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-arrow-left me-1"></i>Back</a>
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning"><i class="bi bi-pencil me-1"></i>Edit</a>
    </div>
</div>
