@model IEnumerable<FinalProject.Models.Trainee>
@{ ViewData["Title"] = "Trainees"; }
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="text-primary"><i class="bi bi-people me-2"></i>Trainees Directory</h2>
    <a asp-action="Add" class="btn btn-primary rounded-pill px-4"><i class="bi bi-plus-circle me-2"></i>Add Trainee</a>
</div>
<div class="card shadow-sm border-0 mb-4">
    <div class="card-body p-0 table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light"><tr><th>Name</th><th>Department</th><th>Grade</th><th>Address</th><th class="text-end pe-4">Actions</th></tr></thead>
            <tbody>
                @foreach(var item in Model) {
                <tr>
                    <td class="ps-3 fw-bold text-primary">@item.Name</td>
                    <td><span class="badge bg-info text-dark">@(item.Department?.Name ?? "N/A")</span></td>
                    <td>@item.Grade</td>
                    <td>@item.Address</td>
                    <td class="text-end pe-3">
                        <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline" onsubmit="return confirm('Delete this trainee?');">
                        <div class="btn-group btn-group-sm">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-primary"><i class="bi bi-pencil"></i></a>
                            <button type="submit" class="btn btn-outline-danger"><i class="bi bi-trash"></i></button>
                        </div>
                        </form>
                    </td>
                </tr>
                }
            </tbody>
        </table>
    </div>
</div>
