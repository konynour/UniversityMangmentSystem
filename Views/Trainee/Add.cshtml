@model FinalProject.Models.Trainee
@{ ViewData["Title"] = "Add Trainee"; }
<div class="card shadow-sm mx-auto mt-4" style="max-width: 600px;">
  <div class="card-header bg-primary text-white"><i class="bi bi-people me-2"></i><h5 class="d-inline mb-0">Add Trainee</h5></div>
  <div class="card-body p-4">
    <form asp-action="Add" method="post">
      <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
      <div class="mb-3">
        <label asp-for="Name" class="form-label fw-bold"></label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger small"></span>
      </div>
      <div class="row">
        <div class="col-md-6 mb-3">
            <label asp-for="Grade" class="form-label fw-bold"></label>
            <input asp-for="Grade" type="number" step="0.01" class="form-control" />
            <span asp-validation-for="Grade" class="text-danger small"></span>
        </div>
        <div class="col-md-6 mb-3">
            <label asp-for="Dept_Id" class="form-label fw-bold">Department</label>
            <select asp-for="Dept_Id" class="form-select" asp-items="ViewBag.Depts"><option value="">-- Select --</option></select>
            <span asp-validation-for="Dept_Id" class="text-danger small"></span>
        </div>
        <div class="col-12 mb-3">
            <label asp-for="Address" class="form-label fw-bold"></label>
            <input asp-for="Address" class="form-control" />
            <span asp-validation-for="Address" class="text-danger small"></span>
        </div>
        <div class="col-12 mb-3">
            <label asp-for="Image" class="form-label fw-bold">Image URL</label>
            <input asp-for="Image" class="form-control" placeholder="https://..." />
            <span asp-validation-for="Image" class="text-danger small"></span>
        </div>
      </div>
      <div class="d-flex justify-content-end gap-2 mt-4">
        <a asp-action="Index" class="btn btn-light border rounded-pill px-4">Cancel</a>
        <button type="submit" class="btn btn-primary rounded-pill px-5"><i class="bi bi-save me-2"></i>Save Trainee</button>
      </div>
    </form>
  </div>
</div>
