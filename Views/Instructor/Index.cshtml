@model IEnumerable<FinalProject.Models.Instructor>
@{ ViewData["Title"] = "Instructors Directory"; }
<div class="page-header d-flex justify-content-between align-items-center mb-4 p-3 bg-white rounded shadow-sm">
    <div><h2 class="mb-0 text-primary"><i class="bi bi-person-workspace me-2"></i>Instructors Directory</h2></div>
    <a asp-action="Add" class="btn btn-primary rounded-pill px-4"><i class="bi bi-plus-circle me-2"></i>Add Instructor</a>
</div>
<div class="card shadow-sm border-0 mb-4">
    <div class="card-body">
        <form asp-action="Index" method="get" class="mb-4">
            <div class="input-group w-50">
                <span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-muted"></i></span>
                <input type="text" name="search" class="form-control border-start-0 ps-0" placeholder="Search instructors by name..." value="@ViewBag.Search">
                <button class="btn btn-outline-secondary" type="submit">Search</button>
                @if (!string.IsNullOrEmpty(ViewBag.Search)) { <a asp-action="Index" class="btn btn-light border">Clear</a> }
            </div>
        </form>
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr><th>Name</th><th>Department</th><th>Course</th><th>Salary</th><th class="text-end">Actions</th></tr>
                </thead>
                <tbody>
                    @foreach (var item in Model) {
                        <tr>
                            <td><span class="fw-semibold"><i class="bi bi-person-circle me-2 text-secondary"></i>@item.Name</span></td>
                            <td><span class="badge bg-info text-dark">@(item.Department?.Name ?? "N/A")</span></td>
                            <td><span class="badge bg-light text-dark border">@(item.Course?.Name ?? "N/A")</span></td>
                            <td>@item.Salary.ToString("C")</td>
                            <td class="text-end">
                                <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this instructor?');">
                                    <div class="btn-group btn-group-sm">
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-info" title="View"><i class="bi bi-eye"></i></a>
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-primary" title="Edit"><i class="bi bi-pencil"></i></a>
                                        <button type="submit" class="btn btn-outline-danger" title="Delete"><i class="bi bi-trash"></i></button>
                                    </div>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
