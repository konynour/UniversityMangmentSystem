@{
    ViewData["Title"] = "VarsityHub Dashboard";
}

<div class="row align-items-center mb-5 mt-3">
    <div class="col-lg-6">
        <div class="pe-lg-5">
            <span class="badge bg-primary bg-opacity-10 text-primary mb-3">v2.0 Admin Portal</span>
            <h1 class="display-4 fw-bolder mb-3" style="letter-spacing:-1px; color:#0f172a;">Manage Your <br/><span style="color:var(--primary-color);">Institution</span> Effortlessly.</h1>
            <p class="lead text-muted mb-4">A unified, real-time control center for university administrators. Instantly navigate departments, track instructor load, configure courses, and grade trainees from one beautiful interface.</p>
            <div class="d-flex gap-2">
                <a asp-controller="Department" asp-action="Index" class="btn btn-primary btn-lg shadow-sm">Get Started <i class="bi bi-arrow-right ms-2"></i></a>
                <a href="#stats" class="btn btn-outline-secondary btn-lg bg-white">View Statistics</a>
            </div>
        </div>
    </div>
    <div class="col-lg-6 d-none d-lg-block">
        <div class="p-4 bg-white border border-light rounded-4 shadow-sm position-relative overflow-hidden">
            <div class="position-absolute top-0 start-0 w-100 h-100 bg-light opacity-50" style="background: repeating-linear-gradient(45deg, #f1f5f9, #f1f5f9 10px, #ffffff 10px, #ffffff 20px);"></div>
            <img src="~/images/CollegeLogo.png" alt="University" class="img-fluid position-relative z-1 d-block mx-auto" style="height:320px; filter: drop-shadow(0 20px 30px rgba(99,102,241,0.2));" />
        </div>
    </div>
</div>

<div id="stats" class="mt-5 pt-3">
    <div class="d-flex align-items-center mb-4">
        <h3 class="mb-0 fw-bold">Platform Modules</h3>
        <div class="ms-auto">
            <span class="fs-6 text-muted"><i class="bi bi-circle-fill text-success fs-6 me-1" style="font-size:8px!important;"></i> System Online</span>
        </div>
    </div>

    <div class="row g-4">
        <!-- Module 1 -->
        <div class="col-xl-3 col-md-6">
            <div class="card h-100 border-0 shadow-sm" style="background: linear-gradient(145deg, #ffffff, #f8fafc);">
                <div class="card-body p-4 position-relative">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <div class="bg-primary bg-opacity-10 text-primary rounded-3 p-3 d-inline-flex">
                            <i class="bi bi-building fs-3"></i>
                        </div>
                    </div>
                    <h5 class="fw-bold mb-1">Departments</h5>
                    <p class="text-muted small mb-4">Manage faculties, locations, and head managers seamlessly.</p>
                    <a asp-controller="Department" asp-action="Index" class="btn btn-sm btn-light w-100 text-primary fw-semibold border">Manage Departments</a>
                </div>
            </div>
        </div>

        <!-- Module 2 -->
        <div class="col-xl-3 col-md-6">
            <div class="card h-100 border-0 shadow-sm" style="background: linear-gradient(145deg, #ffffff, #f8fafc);">
                <div class="card-body p-4 position-relative">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <div class="bg-success bg-opacity-10 text-success rounded-3 p-3 d-inline-flex">
                            <i class="bi bi-person-workspace fs-3"></i>
                        </div>
                    </div>
                    <h5 class="fw-bold mb-1">Instructors</h5>
                    <p class="text-muted small mb-4">View staff directories, salary details, and academic assignments.</p>
                    <a asp-controller="Instructor" asp-action="Index" class="btn btn-sm btn-light w-100 text-success fw-semibold border">Manage Instructors</a>
                </div>
            </div>
        </div>

        <!-- Module 3 -->
        <div class="col-xl-3 col-md-6">
            <div class="card h-100 border-0 shadow-sm" style="background: linear-gradient(145deg, #ffffff, #f8fafc);">
                <div class="card-body p-4 position-relative">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <div class="bg-warning bg-opacity-10 text-warning rounded-3 p-3 d-inline-flex">
                            <i class="bi bi-journal-bookmark fs-3"></i>
                        </div>
                    </div>
                    <h5 class="fw-bold mb-1">Courses</h5>
                    <p class="text-muted small mb-4">Design syllabus, configure passing grades, and assign credits.</p>
                    <a asp-controller="Course" asp-action="Index" class="btn btn-sm btn-light w-100 text-warning fw-semibold border">Manage Courses</a>
                </div>
            </div>
        </div>

        <!-- Module 4 -->
        <div class="col-xl-3 col-md-6">
            <div class="card h-100 border-0 shadow-sm" style="background: linear-gradient(145deg, #ffffff, #f8fafc);">
                <div class="card-body p-4 position-relative">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <div class="bg-danger bg-opacity-10 text-danger rounded-3 p-3 d-inline-flex">
                            <i class="bi bi-mortarboard fs-3"></i>
                        </div>
                    </div>
                    <h5 class="fw-bold mb-1">Trainees</h5>
                    <p class="text-muted small mb-4">Access student grades, track performance, and enrollments data.</p>
                    <a asp-controller="Trainee" asp-action="Index" class="btn btn-sm btn-light w-100 text-danger fw-semibold border">Manage Trainees</a>
                </div>
            </div>
        </div>
    </div>
</div>
